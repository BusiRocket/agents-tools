{
  "name": "busirocket-agents-tools",
  "version": "1.0.0",
  "private": true,
  "description": "Agent workflow engine + rules/skills orchestrator for high-quality code across IDEs",
  "scripts": {
    "build": "pnpm run clean:dist && pnpm run rules:compile && pnpm run skills:compile",
    "check:all": "pnpm run format && pnpm run lint:fix && pnpm run rules:check && pnpm run skills:validate && pnpm run skills:test",
    "check:ci": "pnpm run check:all",
    "check": "pnpm run check:all",
    "format:check": "prettier --check .",
    "format": "prettier --write . --list-different",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "clean:dist": "node -e \"require('node:fs/promises').rm('dist', { recursive: true, force: true })\"",
    "rules:check": "tsx scripts/bin/run-compile-rules.ts --check",
    "rules:compile": "tsx scripts/bin/run-compile-rules.ts",
    "rules:verify": "tsx scripts/commands/verifyRulesOutput.ts",
    "rules:link": "tsx scripts/bin/run-link-rules-global.ts",
    "skills:compile": "tsx scripts/bin/run-compile-skills.ts",
    "skills:inventory": "tsx scripts/commands/skillsInventory.ts",
    "skills:link": "tsx scripts/bin/run-link-skills-global.ts",
    "skills:link:antigravity": "tsx scripts/bin/run-install-antigravity-skills.ts",
    "skills:package": "tsx scripts/commands/packageSkills.ts",
    "skills:llms": "tsx scripts/bin/run-generate-llms-txt.ts",
    "skills:prompt:file": "tsx scripts/bin/run-to-prompt.ts > available_skills.xml",
    "skills:prompt": "tsx scripts/bin/run-to-prompt.ts",
    "skills:test": "tsx scripts/commands/testSkills.ts",
    "skills:validate": "tsx scripts/commands/validateSkills.ts",
    "skills:version:check": "tsx scripts/bin/run-check-version.ts",
    "sync": "pnpm install && pnpm run build && pnpm run check && pnpm run rules:link && pnpm run skills:link",
    "update": "pnpm update && pnpm run sync",
    "validate:install": "python3 -m venv .venv-validate && .venv-validate/bin/pip install skills-ref"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-code-policy": "^0.2.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "ts-morph": "^27.0.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/BusiRocket/busirocket-agents-tools.git"
  },
  "license": "MIT"
}
