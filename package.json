{
  "name": "busirocket-agents-tools",
  "version": "1.0.0",
  "private": true,
  "description": "Agent workflow engine + rules/skills orchestrator for high-quality code across IDEs",
  "scripts": {
    "build": "pnpm run rules:compile && pnpm run skills:compile",
    "check:all": "pnpm run format && pnpm run lint:fix && pnpm run rules:check && pnpm run skills:validate && pnpm run skills:test",
    "check:ci": "pnpm run check:all",
    "check": "pnpm run check:all",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "rules:check": "node scripts/compile-rules.mjs --check",
    "rules:compile": "node scripts/compile-rules.mjs",
    "rules:verify": "node scripts/verify-rules-output.mjs",
    "rules:link": "node scripts/link-rules-global.mjs",
    "skills:compile": "node scripts/compile-skills.mjs",
    "skills:inventory": "node scripts/skills-inventory.mjs",
    "skills:link": "node scripts/link-skills-global.mjs",
    "skills:package": "node scripts/package-skills.mjs",
    "skills:llms": "node scripts/generate-llms-txt.mjs",
    "skills:prompt:file": "node scripts/to-prompt.mjs > available_skills.xml",
    "skills:prompt": "node scripts/to-prompt.mjs",
    "skills:test": "node scripts/test-skills.mjs",
    "skills:validate": "node scripts/validate-skills.mjs",
    "skills:version:check": "node scripts/check-version.mjs",
    "sync": "pnpm install && pnpm run build && pnpm run check && pnpm run rules:link && pnpm run skills:link",
    "update": "pnpm update && pnpm run sync",
    "validate:install": "python3 -m venv .venv-validate && .venv-validate/bin/pip install skills-ref"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.30.3",
  "repository": {
    "type": "git",
    "url": "https://github.com/BusiRocket/busirocket-agents-tools.git"
  },
  "license": "MIT"
}
