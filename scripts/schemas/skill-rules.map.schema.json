{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://busirocket.dev/schemas/skill-rules.map.schema.json",
  "title": "Skill Rules Manifest",
  "type": "object",
  "required": ["version", "skills"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "skills": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[a-z0-9-]+$": {
          "type": "object",
          "required": ["rules"],
          "additionalProperties": false,
          "properties": {
            "rules": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "pattern": "^@rules\\/.+\\.mdc$"
              },
              "uniqueItems": true
            }
          }
        }
      },
      "additionalProperties": false
    }
  }
}
